{
  "name": "vectorgrep",
  "displayName": "VectorGrep",
  "description": "VS Code client for semantic code search",
  "version": "0.0.1",
  "publisher": "harshgarg10",
  "repository": {
    "type": "git",
    "url": "https://github.com/harshgarg10/vectorgrep"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
  "onView:vectorgrepSidebar"
],
  "main": "./out/extension.js",
  "contributes": {
  "viewsContainers": {
    "activitybar": [
      {
        "id": "vectorgrepContainer",
        "title": "VectorGrep",
        "icon": "media/icon.svg"
      }
    ]
  },
  "views": {
    "vectorgrepContainer": [
      {
        "id": "vectorgrepSidebar",
        "name": "VectorGrep Search",
        "type": "webview"
      }
    ]
  },
  "commands": [
    {
      "command": "vectorgrep.helloWorld",
      "title": "Hello World"
    }
  ]
},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
